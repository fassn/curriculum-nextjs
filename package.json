{
  "name": "curriculum-nextjs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:local:up": "docker compose -f docker-compose.local-postgres.yml up -d",
    "db:local:down": "docker compose -f docker-compose.local-postgres.yml down",
    "db:local:down:volumes": "docker compose -f docker-compose.local-postgres.yml down -v",
    "db:local:logs": "docker compose -f docker-compose.local-postgres.yml logs -f postgres",
    "db:local:bootstrap": "bash ./scripts/db-local-bootstrap.sh",
    "db:local:reset": "bash ./scripts/db-local-reset.sh",
    "db:generate": "prisma generate",
    "env:check": "node scripts/check-env.mjs",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed:admin": "node prisma/scripts/seed-admin-user.mjs",
    "db:seed:sample-posts": "node prisma/scripts/seed-sample-posts.mjs"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@prisma/client": "^6.19.3",
    "@tinymce/tinymce-react": "^6.3.0",
    "bcryptjs": "^3.0.3",
    "isomorphic-dompurify": "^3.9.0",
    "jose": "^6.1.0",
    "moment": "^2.30.1",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-google-recaptcha-v3": "^1.11.0",
    "sharp": "^0.34.5",
    "tinymce": "^8.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
